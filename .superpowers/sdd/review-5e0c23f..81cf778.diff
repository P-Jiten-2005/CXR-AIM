+    success = camera_service.start_camera(source)
+    if not success:
+        raise HTTPException(status_code=400, detail=f"Failed to connect to camera source: {source}")
+    
+    camera_service.set_active_session(session_id)
+    return {
+        "success": True,
+        "session_id": session_id,
